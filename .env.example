# Movie Rec Agent - 环境变量配置示例

# LLM 配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-3.5-turbo

# 数据库配置（本地开发用 localhost，Docker 环境会自动覆盖为服务名）
DATABASE_URL=postgresql+asyncpg://funrec:funrec123@localhost:5432/funrec_db

# Redis 配置（本地开发用 localhost，Docker 环境会自动覆盖为 redis）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 传统推荐系统地址（本地开发用 localhost，Docker 环境用服务名 backend）
TRAD_REC_BASE_URL=http://localhost:8000

# 日志配置
LOG_LEVEL=INFO
